<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_CSVLogger" Id="{8a84e9fd-9a8f-453a-90ca-561ec719d60c}" SpecialFunc="None">
    <Declaration><![CDATA[(*  FB_CsvLogger
  ============
  Writes valve and sensor snapshots to CSV files on the IPC filesystem.

  File naming:
    <BasePath><Prefix><YYYY-MM-DD>.csv
  Example:
    C:\TwinCAT\IrrigationLogs\Irrigation_2026-04-28.csv

  Why a state machine?
    TwinCAT file function blocks are asynchronous (non-blocking). Each file
    action may require several PLC cycles to complete. This FB advances through
    explicit states so it remains deterministic and easy to troubleshoot.
*)

FUNCTION_BLOCK FB_CsvLogger

VAR_INPUT
  bEnable              : BOOL := TRUE;
  bForceWrite          : BOOL;          (* Rising edge = write one row immediately    *)
  tLogInterval         : TIME;          (* Periodic write interval                     *)
  sBasePath            : STRING(128);   (* Folder path including trailing '\'         *)
  sPrefix              : T_MaxString;   (* File prefix, e.g. 'Irrigation_'             *)
  stValve              : ARRAY[1..3] OF ST_ValveData;
  rWaterLevel_Percent  : REAL;
  rTemperature_C       : REAL;
END_VAR

VAR_OUTPUT
  bBusy                : BOOL;
  bError               : BOOL;
  nErrorCode           : UDINT;
  bFileExists          : BOOL := FALSE;
  dtLastWrite          : DT;
  sCurrentFile         : STRING(128);
  sCurrentFilename     : STRING(128);
  eState               : E_CSVLogState := E_CSVLogState.CSV_IDLE;
END_VAR

VAR
  (* ── File I/O FBs ───────────────────────────────────────── *)
  fbFileOpen           : FB_FileOpen;
  fbFileWrite          : FB_FileWrite;
  fbFileClose          : FB_FileClose;
  fbEnum               : FB_EnumFindFileEntry;

  hFilenumber          : UINT;
  cbLen                : UDINT;

  (* ── Trigger handling ───────────────────────────────────── *)
  tIntervalTimer       : TON;
  rtForceWrite         : R_TRIG;
  bTriggerWrite        : BOOL;

  (* ── Time/date helpers ──────────────────────────────────── *)
  fbGetTime            : FB_LocalSystemTime;
  nYear                : UINT;
  nMonth               : UINT;
  nDay                 : UINT;
  sYear                : STRING(8);
  sMonth               : STRING(4);
  sDay                 : STRING(4);

  (* ── CSV string buffers ─────────────────────────────────── *)
  sLine                : STRING(512);
  sHeader              : STRING(512);
  sSource              : STRING(8);

  (* ── Internal state helpers ─────────────────────────────── *)
  bEnumStart           : BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ============================================================
   SECTION 1 — CYCLIC HOUSEKEEPING
   ============================================================ *)
fbGetTime(bEnable := TRUE, dwCycle := 1);

// If logger is disabled, remain safe and idle.
IF NOT bEnable THEN
  tIntervalTimer(IN := FALSE);
  bTriggerWrite := FALSE;
  bBusy := FALSE;

  IF hFilenumber <> 0 THEN
    // Close any leftover open file handle before returning to idle.
    fbFileClose(hFile := hFilenumber, bExecute := TRUE);
    IF NOT fbFileClose.bBusy THEN
      fbFileClose(bExecute := FALSE);
      hFilenumber := 0;
    END_IF
  END_IF

  eState := E_CSVLogState.CSV_IDLE;
  RETURN;
END_IF

rtForceWrite(CLK := bForceWrite);
tIntervalTimer(IN := TRUE, PT := tLogInterval);

bTriggerWrite := rtForceWrite.Q OR tIntervalTimer.Q;

IF tIntervalTimer.Q THEN
  // Retrigger periodic timer after each elapsed interval.
  tIntervalTimer(IN := FALSE);
END_IF


(* ============================================================
   SECTION 2 — LOGGER STATE MACHINE
   ============================================================ *)
CASE eState OF

  E_CSVLogState.CSV_IDLE:
    bBusy := FALSE;

    IF bTriggerWrite THEN
      bError := FALSE;
      nErrorCode := 0;
      bFileExists := FALSE;
      bEnumStart := TRUE;
      eState := E_CSVLogState.CSV_PREPARE;
    END_IF


  E_CSVLogState.CSV_PREPARE:
    // Build filename as Prefix + YYYY-MM-DD.csv (daily file rotation).
    nYear  := fbGetTime.systemTime.wYear;
    nMonth := fbGetTime.systemTime.wMonth;
    nDay   := fbGetTime.systemTime.wDay;

    sYear  := UINT_TO_STRING(nYear);
    sMonth := UINT_TO_STRING(nMonth);
    sDay   := UINT_TO_STRING(nDay);

    IF nMonth < 10 THEN
      sMonth := CONCAT('0', sMonth);
    END_IF

    IF nDay < 10 THEN
      sDay := CONCAT('0', sDay);
    END_IF

    sCurrentFilename := sPrefix;
    sCurrentFilename := CONCAT(sCurrentFilename, sYear);
    sCurrentFilename := CONCAT(sCurrentFilename, '-');
    sCurrentFilename := CONCAT(sCurrentFilename, sMonth);
    sCurrentFilename := CONCAT(sCurrentFilename, '-');
    sCurrentFilename := CONCAT(sCurrentFilename, sDay);
    sCurrentFilename := CONCAT(sCurrentFilename, '.csv');

    sCurrentFile := CONCAT(sBasePath, sCurrentFilename);

    // Determine whether file already exists (header needed only for new files).
    IF bEnumStart THEN
      fbEnum(
        sPathName := sCurrentFile,
        eCmd := eEnumCmd_First,
        bExecute := TRUE,
        tTimeout := T#2S
      );
      bEnumStart := FALSE;
    ELSE
      fbEnum(bExecute := FALSE);
    END_IF

    IF NOT fbEnum.bBusy THEN
      fbEnum(bExecute := FALSE);

      IF (NOT fbEnum.bError) AND (fbEnum.stFindFile.sFileName <> '') THEN
        bFileExists := TRUE;
      ELSE
        bFileExists := FALSE;
      END_IF

      eState := E_CSVLogState.CSV_OPEN;
    END_IF


  E_CSVLogState.CSV_OPEN:
    bBusy := TRUE;

    fbFileOpen(
      sPathName := sCurrentFile,
      nMode     := FOPEN_MODEAPPEND,
      bExecute  := TRUE,
      hFile     => hFilenumber
    );

    IF NOT fbFileOpen.bBusy THEN
      fbFileOpen(bExecute := FALSE);

      IF fbFileOpen.bError THEN
        nErrorCode := fbFileOpen.nErrId;
        bError := TRUE;
        eState := E_CSVLogState.CSV_ERROR;
      ELSE
        hFilenumber := fbFileOpen.hFile;

        IF bFileExists THEN
          eState := E_CSVLogState.CSV_WRITE_ROW;
        ELSE
          eState := E_CSVLogState.CSV_WRITE_HDR;
        END_IF
      END_IF
    END_IF


  E_CSVLogState.CSV_WRITE_HDR:
    // Header is written exactly once per newly created daily file.
    sHeader := 'Timestamp,V1_Setpoint_%,V1_Actual_%,V1_Source,V2_Setpoint_%,V2_Actual_%,V2_Source,V3_Setpoint_%,V3_Actual_%,V3_Source,WaterLevel_%,Temperature_C$R$N';
    cbLen := INT_TO_UDINT(LEN(sHeader));

    fbFileWrite(
      bExecute   := TRUE,
      hFile      := hFilenumber,
      pWriteBuff := ADR(sHeader),
      cbWriteLen := cbLen
    );

    IF NOT fbFileWrite.bBusy THEN
      fbFileWrite(bExecute := FALSE);

      IF fbFileWrite.bError THEN
        nErrorCode := fbFileWrite.nErrId;
        bError := TRUE;
        eState := E_CSVLogState.CSV_CLOSE;
      ELSE
        eState := E_CSVLogState.CSV_WRITE_ROW;
      END_IF
    END_IF


  E_CSVLogState.CSV_WRITE_ROW:
    // Compose one CSV line from the latest process snapshot.
    sLine := CONCAT(SYSTEMTIME_TO_STRING(fbGetTime.systemTime), ',');

    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(stValve[1].Active_Setpoint), ','));
    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(stValve[1].Actual_Position), ','));
    sSource := TO_STRING(stValve[1].Source);
    sLine := CONCAT(sLine, CONCAT(sSource, ','));

    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(stValve[2].Active_Setpoint), ','));
    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(stValve[2].Actual_Position), ','));
    sSource := TO_STRING(stValve[2].Source);
    sLine := CONCAT(sLine, CONCAT(sSource, ','));

    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(stValve[3].Active_Setpoint), ','));
    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(stValve[3].Actual_Position), ','));
    sSource := TO_STRING(stValve[3].Source);
    sLine := CONCAT(sLine, CONCAT(sSource, ','));

    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(rWaterLevel_Percent), ','));
    sLine := CONCAT(sLine, CONCAT(REAL_TO_STRING(rTemperature_C), '$R$N'));

    cbLen := INT_TO_UDINT(LEN(sLine));

    fbFileWrite(
      bExecute   := TRUE,
      hFile      := hFilenumber,
      pWriteBuff := ADR(sLine),
      cbWriteLen := cbLen
    );

    IF NOT fbFileWrite.bBusy THEN
      fbFileWrite(bExecute := FALSE);

      IF fbFileWrite.bError THEN
        nErrorCode := fbFileWrite.nErrId;
        bError := TRUE;
      ELSE
        bError := FALSE;
        dtLastWrite := SYSTEMTIME_TO_DT(fbGetTime.systemTime);
      END_IF

      eState := E_CSVLogState.CSV_CLOSE;
    END_IF


  E_CSVLogState.CSV_CLOSE:
    fbFileClose(hFile := hFilenumber, bExecute := TRUE);

    IF NOT fbFileClose.bBusy THEN
      fbFileClose(bExecute := FALSE);
      hFilenumber := 0;
      bBusy := FALSE;
      eState := E_CSVLogState.CSV_IDLE;
    END_IF


  E_CSVLogState.CSV_ERROR:
    bBusy := FALSE;
    bError := TRUE;

    // Recovery strategy: on next trigger, retry from preparation phase.
    IF bTriggerWrite THEN
      eState := E_CSVLogState.CSV_PREPARE;
    END_IF

END_CASE
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
